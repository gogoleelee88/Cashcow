# ─────────────────────────────────────────────
# DATABASE
# ─────────────────────────────────────────────
DATABASE_URL="postgresql://characterverse:password@localhost:5432/characterverse?schema=public&connection_limit=10&pool_timeout=20"
DATABASE_DIRECT_URL="postgresql://characterverse:password@localhost:5432/characterverse?schema=public"
DATABASE_READ_URL="postgresql://characterverse:password@localhost:5433/characterverse?schema=public"

# ─────────────────────────────────────────────
# REDIS
# ─────────────────────────────────────────────
REDIS_URL="redis://:redis_password@localhost:6379"
REDIS_TLS="false"

# ─────────────────────────────────────────────
# SERVER
# ─────────────────────────────────────────────
NODE_ENV="development"
PORT="4000"
HOST="0.0.0.0"
API_BASE_URL="http://localhost:4000"
WEB_BASE_URL="http://localhost:3000"
ALLOWED_ORIGINS="http://localhost:3000,http://localhost:19006"

# ─────────────────────────────────────────────
# JWT
# ─────────────────────────────────────────────
JWT_ACCESS_SECRET="change-me-to-a-very-long-random-string-at-least-64-chars-in-production"
JWT_REFRESH_SECRET="change-me-to-another-very-long-random-string-for-refresh-tokens"
JWT_ACCESS_EXPIRES_IN="15m"
JWT_REFRESH_EXPIRES_IN="7d"

# ─────────────────────────────────────────────
# ENCRYPTION (for system prompts at rest)
# ─────────────────────────────────────────────
ENCRYPTION_KEY="change-me-to-exactly-32-bytes-hex-string-in-production-00000000"

# ─────────────────────────────────────────────
# ANTHROPIC AI
# ─────────────────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-..."
ANTHROPIC_HAIKU_MODEL="claude-haiku-4-5-20251001"
ANTHROPIC_SONNET_MODEL="claude-sonnet-4-6"

# ─────────────────────────────────────────────
# AWS S3
# ─────────────────────────────────────────────
AWS_REGION="ap-northeast-2"
AWS_ACCESS_KEY_ID="AKIA..."
AWS_SECRET_ACCESS_KEY="..."
AWS_S3_BUCKET="characterverse-assets"
AWS_CLOUDFRONT_URL="https://d1234567890.cloudfront.net"

# ─────────────────────────────────────────────
# OAUTH PROVIDERS
# ─────────────────────────────────────────────
GOOGLE_CLIENT_ID="..."
GOOGLE_CLIENT_SECRET="..."
KAKAO_CLIENT_ID="..."
KAKAO_CLIENT_SECRET="..."
APPLE_CLIENT_ID="..."
APPLE_TEAM_ID="..."
APPLE_KEY_ID="..."
APPLE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"

# ─────────────────────────────────────────────
# PAYMENTS
# ─────────────────────────────────────────────
TOSS_CLIENT_KEY="test_ck_..."
TOSS_SECRET_KEY="test_sk_..."
TOSS_WEBHOOK_SECRET="..."
STRIPE_PUBLISHABLE_KEY="pk_test_..."
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."

# ─────────────────────────────────────────────
# MONITORING
# ─────────────────────────────────────────────
SENTRY_DSN="https://...@sentry.io/..."
SLACK_WEBHOOK_URL="https://hooks.slack.com/services/..."
LOG_LEVEL="info"
PROMETHEUS_PORT="9090"
