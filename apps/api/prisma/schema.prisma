// ============================================================
// CharacterVerse вҖ” Production Prisma Schema
// PostgreSQL with full normalization, indexes, and audit trails
// ============================================================

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["fullTextSearch", "metrics", "tracing"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_DIRECT_URL")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// ENUMS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum UserRole {
  USER
  CREATOR
  ADMIN
}

enum SubscriptionTier {
  FREE
  BASIC
  PRO
  ENTERPRISE
}

enum OAuthProvider {
  GOOGLE
  KAKAO
  APPLE
}

enum CharacterVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum CharacterCategory {
  ANIME
  GAME
  MOVIE
  BOOK
  ORIGINAL
  CELEBRITY
  HISTORICAL
  VTUBER
  OTHER
}

enum AgeRating {
  ALL
  TEEN
  MATURE
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

enum MessageStatus {
  SENT
  ERROR
  FILTERED
}

enum TransactionType {
  PURCHASE
  USAGE
  REFUND
  BONUS
  SETTLEMENT
}

enum PaymentStatus {
  PENDING
  COMPLETED
  FAILED
  REFUNDED
  CANCELLED
}

enum PaymentProvider {
  TOSS
  STRIPE
}

enum NotificationType {
  NEW_FOLLOWER
  CHARACTER_LIKE
  CHARACTER_COMMENT
  SYSTEM
  CREDIT_LOW
  SETTLEMENT_COMPLETE
}

enum SettlementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

enum CharacterGender {
  MALE
  FEMALE
  MIXED
  NEUTRAL
}

enum AudienceTarget {
  ALL
  MALE_ORIENTED   // Characters popular with male users (typically female characters)
  FEMALE_ORIENTED // Characters popular with female users (typically male characters)
}

enum AuditAction {
  CREATE
  UPDATE
  DELETE
  LOGIN
  LOGOUT
  PAYMENT
  SETTLEMENT
  SUSPENSION
  RESTORE
}

enum StoryCategory {
  ROMANCE
  FANTASY
  MYSTERY
  THRILLER
  SF
  HISTORICAL
  HORROR
  COMEDY
  ADVENTURE
  SLICE_OF_LIFE
  OTHER
}

enum StoryStatus {
  DRAFT
  ONGOING
  COMPLETED
  HIATUS
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// USERS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model User {
  id               String           @id @default(cuid())
  email            String?          @unique
  username         String           @unique
  displayName      String
  passwordHash     String?
  avatarUrl        String?
  bio              String?          @db.Text
  role             UserRole         @default(USER)
  subscriptionTier SubscriptionTier @default(FREE)
  creditBalance    Int              @default(0)
  isVerified       Boolean          @default(false)
  isActive         Boolean          @default(true)
  isBanned         Boolean          @default(false)
  banReason        String?
  bannedUntil      DateTime?
  ageVerified      Boolean          @default(false)
  ageVerifiedAt    DateTime?
  lastLoginAt      DateTime?
  preferredGenres  String           @default("[]") @db.Text
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  // Relations
  oauthAccounts    OAuthAccount[]
  refreshTokens    RefreshToken[]
  characters       Character[]
  conversations    Conversation[]
  transactions     Transaction[]
  notifications    Notification[]
  subscriptions    Subscription[]
  settlements      Settlement[]
  creatorProfile   CreatorProfile?
  likes            CharacterLike[]
  favorites        CharacterFavorite[]
  followers        Follow[]         @relation("Following")
  following        Follow[]         @relation("Follower")
  reports          Report[]         @relation("Reporter")
  reportedContent  Report[]         @relation("Reported")
  auditLogs        AuditLog[]
  stories          Story[]
  storyConversations StoryConversation[]
  storyLikes       StoryLike[]
  storyFavorites   StoryFavorite[]
  generatedImages  GeneratedImage[]
  characterDraft   CharacterDraft?
  profiles         Profile[]
  characterComments CharacterComment[]
  commentReactions  CharacterCommentReaction[]
  appeals           Appeal[]

  @@index([email])
  @@index([username])
  @@index([role])
  @@index([createdAt])
  @@map("users")
}

model Profile {
  id          String   @id @default(cuid())
  userId      String
  name        String   @db.VarChar(20)
  isKids      Boolean  @default(false)
  pinHash     String?
  avatarEmoji String   @default("рҹҳҠ")
  avatarColor String   @default("#E63325")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("profiles")
}

model OAuthAccount {
  id             String        @id @default(cuid())
  userId         String
  provider       OAuthProvider
  providerId     String
  accessToken    String?       @db.Text
  refreshToken   String?       @db.Text
  expiresAt      DateTime?
  rawProfile     Json?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  user           User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerId])
  @@index([userId])
  @@map("oauth_accounts")
}

model RefreshToken {
  id          String    @id @default(cuid())
  userId      String
  tokenHash   String    @unique
  family      String    // Token family for rotation detection
  isUsed      Boolean   @default(false)
  userAgent   String?
  ipAddress   String?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([family])
  @@index([expiresAt])
  @@map("refresh_tokens")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// CREATOR PROFILE
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model CreatorProfile {
  id               String    @id @default(cuid())
  userId           String    @unique
  displayName      String
  bio              String?   @db.Text
  website          String?
  socialLinks      Json?
  totalEarnings    Int       @default(0)  // In KRW won
  pendingEarnings  Int       @default(0)
  isPublic         Boolean   @default(true)
  bankInfo         Json?     // Encrypted bank account info
  taxInfo          Json?     // Encrypted tax info
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  user             User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  settlements      Settlement[]

  @@map("creator_profiles")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// CHARACTERS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Character {
  id                   String              @id @default(cuid())
  name                 String
  description          String              @db.Text
  systemPromptEncrypted String             @db.Text  // AES-256-GCM encrypted
  systemPromptIv       String              // IV for decryption
  greeting             String              @db.Text
  prologue             String?             @db.Text  // мұ„нҢ… мӢңмһ‘ мӢң SceneOpeningм—җ н‘ңмӢңлҗҳлҠ” н”„лЎӨлЎңк·ё
  exampleDialogues     Json?               // [{id, messages:[{id,role,content}]}]
  playGuide            String?             @db.Text
  suggestedReplies     Json?               // string[]
  situationImages      Json?               // [{id, url, triggerKeywords:string[], description}] мөңлҢҖ 50к°ң
  avatarUrl            String?
  avatarKey            String?             // S3 key
  backgroundUrl        String?
  backgroundKey        String?             // S3 key
  category             CharacterCategory
  tags                 String[]
  visibility           CharacterVisibility @default(PUBLIC)
  ageRating            AgeRating           @default(ALL)
  language             String              @default("ko")
  model                String              @default("claude-haiku-3")
  temperature          Float               @default(0.8)
  maxTokens            Int                 @default(1024)
  contextWindowSize    Int                 @default(20)  // # of messages to keep
  memoryEnabled        Boolean             @default(true)
  detailDescription    String?             @db.Text  // мәҗлҰӯн„° мғҒм„ё м„ӨлӘ… (мөңлҢҖ 1000мһҗ)
  commentDisabled      Boolean             @default(false)  // лҢ“кёҖ кё°лҠҘ лӢ«кё°
  voiceId              String?
  voiceProvider        String?             // "elevenlabs" | "openai"
  voiceSettings        Json?               // { stability, similarity_boost, style, speed }
  gender               CharacterGender     @default(NEUTRAL)
  audienceTarget       AudienceTarget      @default(ALL)
  isFanCreation        Boolean             @default(false)
  chatCount            Int                 @default(0)
  likeCount            Int                 @default(0)
  favoriteCount        Int                 @default(0)
  trendingScore        Float               @default(0)
  weeklyChats          Int                 @default(0)
  monthlyChats         Int                 @default(0)
  isActive             Boolean             @default(true)
  isFeatured           Boolean             @default(false)
  isOfficial           Boolean             @default(false)
  revenuePerChat       Int                 @default(1)
  reviewStatus         String              @default("AUTO_APPROVED") // AUTO_APPROVED | NEEDS_REVIEW | APPROVED | REJECTED
  reviewNote           String?
  reviewedBy           String?
  reviewedAt           DateTime?
  creatorId            String
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt

  creator              User                @relation(fields: [creatorId], references: [id])
  conversations        Conversation[]
  likes                CharacterLike[]
  favorites            CharacterFavorite[]
  reports              Report[]
  memories             CharacterMemory[]
  storyCharacters      StoryCharacter[]
  comments             CharacterComment[]

  @@index([creatorId])
  @@index([category])
  @@index([visibility])
  @@index([reviewStatus])
  @@index([trendingScore(sort: Desc)])
  @@index([chatCount(sort: Desc)])
  @@index([likeCount(sort: Desc)])
  @@index([weeklyChats(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([tags])
  @@index([audienceTarget])
  @@index([isFanCreation])
  @@index([gender])
  @@index([isOfficial])
  @@map("characters")
}

model CharacterDraft {
  id          String   @id @default(cuid())
  userId      String
  data        Json     // нҸј м „мІҙ лҚ°мқҙн„° (name, description, systemPrompt л“ұ)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId])   // мң м ҖлӢ№ 1к°ң мҙҲм•Ҳл§Ң мң м§Җ
  @@index([userId])
  @@map("character_drafts")
}

model CharacterLike {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([characterId])
  @@map("character_likes")
}

model CharacterFavorite {
  id          String    @id @default(cuid())
  userId      String
  characterId String
  createdAt   DateTime  @default(now())

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([userId, characterId])
  @@index([userId])
  @@index([characterId])
  @@map("character_favorites")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// CONVERSATIONS & MESSAGES
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Conversation {
  id                  String    @id @default(cuid())
  characterId         String
  userId              String
  title               String?
  isPinned            Boolean   @default(false)
  messageCount        Int       @default(0)
  tokenCount          Int       @default(0)
  summary             String?   @db.Text   // лӢЁкё° м••м¶• мҡ”м•Ҫ
  summaryAt           DateTime?
  episodicMemory      Json?               // мӨ‘кё° кё°м–ө: {userFacts, keyEvents, relationshipMilestones}
  episodicUpdatedAt   DateTime?
  relationshipLevel   Int       @default(0)  // м№ңл°ҖлҸ„ 0~100
  emotionalTone       String?              // "л”°лң»н•Ё", "кёҙмһҘ", "м„Өл ҳ" л“ұ
  lastSessionSummary  String?   @db.Text  // м§ҖлӮң м„ём…ҳ мҡ”м•Ҫ (мһ¬м§„мһ… мӢң мқёмӮ¬м—җ нҷңмҡ©)
  generatedGreeting   String?   @db.Text  // лҸҷм Ғ мғқм„ұлҗң мІ« мқёмӮ¬ (мәҗлҰӯн„° м»Ём…ү кё°л°ҳ)
  lastMessageAt       DateTime?
  isActive            Boolean   @default(true)
  metadata            Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  character    Character @relation(fields: [characterId], references: [id])
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages     Message[]

  @@index([userId])
  @@index([characterId])
  @@index([lastMessageAt(sort: Desc)])
  @@index([userId, characterId])
  @@map("conversations")
}

model Message {
  id             String        @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String        @db.Text
  status         MessageStatus @default(SENT)
  inputTokens    Int           @default(0)
  outputTokens   Int           @default(0)
  creditCost     Int           @default(0)
  isFiltered     Boolean       @default(false)
  filterReason   String?
  isHidden       Boolean       @default(false)
  hiddenReason   String?
  hiddenBy       String?
  hiddenAt       DateTime?
  metadata       Json?
  createdAt      DateTime      @default(now())

  conversation   Conversation  @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  flags          ModerationFlag[]

  @@index([conversationId])
  @@index([createdAt])
  @@index([isHidden])
  @@map("messages")
}

model ModerationFlag {
  id          String   @id @default(cuid())
  messageId   String
  category    String
  confidence  Float
  status      String   @default("PENDING")
  autoHidden  Boolean  @default(false)
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime @default(now())

  message     Message  @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
  @@index([status])
  @@index([createdAt])
  @@map("moderation_flags")
}

model Appeal {
  id          String    @id @default(cuid())
  userId      String
  type        String    // MESSAGE_HIDDEN | CHARACTER_HIDDEN | USER_BANNED
  targetId    String    // messageId or characterId
  reason      String    @db.Text
  status      String    @default("PENDING") // PENDING | APPROVED | REJECTED
  adminNote   String?
  reviewedBy  String?
  reviewedAt  DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([status])
  @@index([createdAt])
  @@map("appeals")
}

model CharacterMemory {
  id          String    @id @default(cuid())
  characterId String
  userId      String
  content     String    @db.Text  // Compressed memory
  importance  Int       @default(5) // 1-10 importance score
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([characterId, userId])
  @@map("character_memories")
}

// лӢӨмӨ‘ лҢҖнҷ” к°„ кё°м–ө кіөмң  вҖ” к°ҷмқҖ (мң м Җ Г— мәҗлҰӯн„°) мҢҚмқҳ кё°м–өмқҖ мғҲ лҢҖнҷ”л°©мқ„ л§Ңл“Өм–ҙлҸ„ мқҙм–ҙм§җ
model UserCharacterMemory {
  id                  String    @id @default(cuid())
  userId              String
  characterId         String
  cumulativeSummary   String?   @db.Text   // лҲ„м Ғ кё°м–ө
  userProfile         Json?               // мң м Җ нҢ©нҠё JSON {name, age, likes, dislikes}
  totalInteractions   Int       @default(0)
  firstMetAt          DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  @@unique([userId, characterId])
  @@index([userId])
  @@index([characterId])
  @@map("user_character_memories")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// PAYMENTS & SUBSCRIPTIONS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Transaction {
  id               String          @id @default(cuid())
  userId           String
  type             TransactionType
  amount           Int             // In KRW (if purchase) or credits (if usage)
  credits          Int             @default(0)
  status           PaymentStatus   @default(PENDING)
  provider         PaymentProvider?
  providerOrderId  String?
  providerPaymentId String?
  webhookVerified  Boolean         @default(false)
  description      String
  metadata         Json?
  refundedAt       DateTime?
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt

  user             User            @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([provider, providerOrderId])
  @@index([createdAt(sort: Desc)])
  @@map("transactions")
}

model Subscription {
  id               String           @id @default(cuid())
  userId           String
  tier             SubscriptionTier
  provider         PaymentProvider
  providerSubId    String?
  status           PaymentStatus    @default(PENDING)
  currentPeriodStart DateTime
  currentPeriodEnd DateTime
  cancelAtPeriodEnd Boolean         @default(false)
  cancelledAt      DateTime?
  trialEndsAt      DateTime?
  metadata         Json?
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt

  user             User             @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([status])
  @@index([currentPeriodEnd])
  @@map("subscriptions")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// CREATOR ECONOMY
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Settlement {
  id              String           @id @default(cuid())
  creatorId       String
  creatorProfileId String
  periodStart     DateTime
  periodEnd       DateTime
  totalChats      Int              @default(0)
  grossAmount     Int              @default(0)  // Before platform fee
  platformFeeRate Float            @default(0.3) // 30% platform fee
  platformFee     Int              @default(0)
  netAmount       Int              @default(0)  // After platform fee
  status          SettlementStatus @default(PENDING)
  paidAt          DateTime?
  notes           String?          @db.Text
  auditHash       String?          // SHA-256 of settlement data for tamper detection
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  creator         User             @relation(fields: [creatorId], references: [id])
  creatorProfile  CreatorProfile   @relation(fields: [creatorProfileId], references: [id])
  items           SettlementItem[]

  @@index([creatorId])
  @@index([status])
  @@index([periodStart, periodEnd])
  @@map("settlements")
}

model SettlementItem {
  id            String     @id @default(cuid())
  settlementId  String
  characterId   String
  characterName String
  chatCount     Int
  creditsEarned Int
  amount        Int
  createdAt     DateTime   @default(now())

  settlement    Settlement @relation(fields: [settlementId], references: [id], onDelete: Cascade)

  @@index([settlementId])
  @@map("settlement_items")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// SOCIAL
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Follow {
  id          String   @id @default(cuid())
  followerId  String
  followingId String
  createdAt   DateTime @default(now())

  follower    User     @relation("Follower", fields: [followerId], references: [id], onDelete: Cascade)
  following   User     @relation("Following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followingId])
  @@map("follows")
}

model Notification {
  id        String           @id @default(cuid())
  userId    String
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  data      Json?
  createdAt DateTime         @default(now())

  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, isRead])
  @@index([createdAt(sort: Desc)])
  @@map("notifications")
}

model Report {
  id           String   @id @default(cuid())
  reporterId   String
  reportedId   String
  characterId  String?
  reason       String
  description  String?  @db.Text
  status       String   @default("PENDING")
  resolvedAt   DateTime?
  resolvedBy   String?
  reviewedAt   DateTime?
  reviewedBy   String?
  resolveNote  String?
  createdAt    DateTime @default(now())

  reporter     User      @relation("Reporter", fields: [reporterId], references: [id])
  reported     User      @relation("Reported", fields: [reportedId], references: [id])
  character    Character? @relation(fields: [characterId], references: [id])

  @@index([reporterId])
  @@index([status])
  @@map("reports")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// AUDIT LOG (Tamper-evident)
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model AuditLog {
  id          String      @id @default(cuid())
  userId      String?
  action      AuditAction
  entityType  String
  entityId    String
  oldData     Json?
  newData     Json?
  ipAddress   String?
  userAgent   String?
  requestId   String?
  createdAt   DateTime    @default(now())

  user        User?       @relation(fields: [userId], references: [id])

  @@index([userId])
  @@index([entityType, entityId])
  @@index([action])
  @@index([createdAt(sort: Desc)])
  @@map("audit_logs")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// STORIES (crack.wrtn.ai style interactive stories)
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model Story {
  id               String        @id @default(cuid())
  title            String
  slug             String?       // мһ‘к°Җлі„ unique URL slug (DRAFTлҠ” null)
  description      String        @db.Text
  coverUrl         String?
  coverKey         String?
  category         StoryCategory @default(OTHER)
  tags             String[]
  ageRating        AgeRating     @default(ALL)
  visibility       CharacterVisibility @default(PUBLIC)
  status           StoryStatus   @default(ONGOING)
  language         String        @default("ko")
  chatCount        Int           @default(0)
  likeCount        Int           @default(0)
  favoriteCount    Int           @default(0)
  trendingScore    Float         @default(0)
  isActive         Boolean       @default(true)
  isFeatured       Boolean       @default(false)
  isOfficial       Boolean       @default(false)
  authorId         String
  systemPromptEncrypted String   @db.Text
  systemPromptIv   String
  greeting         String        @db.Text
  chatModel        StoryChatModel @default(SUPER_CHAT_20)
  coverVerticalUrl String?
  coverVerticalKey String?
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt

  author           User          @relation(fields: [authorId], references: [id])
  chapters         StoryChapter[]
  conversations    StoryConversation[]
  likes            StoryLike[]
  favorites        StoryFavorite[]
  characters       StoryCharacter[]
  startSettings    StoryStartSetting[]
  endings          StoryEnding[]
  examples         StoryExample[]

  @@unique([authorId, slug])    // к°ҷмқҖ мһ‘к°Җк°Җ лҸҷмқј slug(=м ңлӘ©) мӨ‘ліө л°ңн–ү л¶Ҳк°Җ. DRAFTлҠ” slug=nullмқҙлҜҖлЎң м ңмҷё
  @@index([authorId])
  @@index([category])
  @@index([visibility])
  @@index([trendingScore(sort: Desc)])
  @@index([chatCount(sort: Desc)])
  @@index([createdAt(sort: Desc)])
  @@index([isOfficial])
  @@map("stories")
}

model StoryExample {
  id             String   @id @default(cuid())
  storyId        String
  userMessage    String   @db.Text
  assistantMessage String @db.Text
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  story          Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@map("story_examples")
}

model StoryChapter {
  id          String    @id @default(cuid())
  storyId     String
  title       String
  content     String    @db.Text
  order       Int
  isPublished Boolean   @default(false)
  scheduledAt DateTime?
  publishedAt DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@index([storyId])
  @@index([scheduledAt])
  @@map("story_chapters")
}

model StoryCharacter {
  id          String    @id @default(cuid())
  storyId     String
  characterId String
  role        String?
  createdAt   DateTime  @default(now())

  story       Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([storyId, characterId])
  @@map("story_characters")
}

model StoryConversation {
  id            String    @id @default(cuid())
  storyId       String
  userId        String
  title         String?
  messageCount  Int       @default(0)
  lastMessageAt DateTime?
  isActive      Boolean   @default(true)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  story         Story     @relation(fields: [storyId], references: [id])
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      StoryMessage[]

  @@index([userId])
  @@index([storyId])
  @@map("story_conversations")
}

model StoryMessage {
  id             String              @id @default(cuid())
  conversationId String
  role           MessageRole
  content        String              @db.Text
  status         MessageStatus       @default(SENT)
  creditCost     Int                 @default(0)
  createdAt      DateTime            @default(now())

  conversation   StoryConversation   @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId])
  @@map("story_messages")
}

model StoryLike {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([storyId])
  @@map("story_likes")
}

model StoryFavorite {
  id        String   @id @default(cuid())
  userId    String
  storyId   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  story     Story    @relation(fields: [storyId], references: [id], onDelete: Cascade)

  @@unique([userId, storyId])
  @@index([userId])
  @@map("story_favorites")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// STORY CHAT MODEL ENUM
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum StoryChatModel {
  HYPER_CHAT      // н•ҳмқҙн”јмұ— - Opus-4.6 - 75 credits
  SUPER_CHAT_25   // мҠҲнҚјмұ— 2.5 - Sonnet-4.6 - 50 credits
  SUPER_CHAT_20   // мҠҲнҚјмұ— 2.0 - Sonnet-4.5 - 50 credits (default)
  SUPER_CHAT_15   // мҠҲнҚјмұ— 1.5 - Sonnet-4.0 - 50 credits
  PRO_CHAT_25     // н”„лЎңмұ— 2.5 - Gemini - 58 credits
  PRO_CHAT_10     // н”„лЎңмұ— 1.0 - Gemini - 50 credits
  POWER_CHAT      // нҢҢмӣҢмұ— - 20 credits
  NORMAL_CHAT     // мқјл°ҳмұ— - free
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// STORY START SETTINGS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
model StoryStartSetting {
  id               String    @id @default(cuid())
  storyId          String
  name             String    @default("кё°ліё м„Өм •")
  prologue         String    @db.Text @default("")
  situation        String    @db.Text @default("")
  playGuide        String?   @db.Text
  order            Int       @default(0)
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  story            Story     @relation(fields: [storyId], references: [id], onDelete: Cascade)
  stats            StoryStat[]
  mediaImages      StoryMediaImage[]
  keywordNotes     StoryKeywordNote[]
  suggestedReplies StorySuggestedReply[]
  endings          StoryEnding[]

  @@index([storyId])
  @@map("story_start_settings")
}

model StorySuggestedReply {
  id             String            @id @default(cuid())
  startSettingId String
  text           String
  order          Int               @default(0)
  createdAt      DateTime          @default(now())

  startSetting   StoryStartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)

  @@index([startSettingId])
  @@map("story_suggested_replies")
}

model StoryStat {
  id             String            @id @default(cuid())
  startSettingId String
  name           String
  icon           String            @default("heart")
  color          String            @default("#E63325")
  minValue       Int               @default(0)
  maxValue       Int               @default(100)
  defaultValue   Int               @default(50)
  unit           String?
  description    String            @db.Text @default("")
  order          Int               @default(0)
  createdAt      DateTime          @default(now())

  startSetting   StoryStartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)
  levels         StoryStatLevel[]

  @@index([startSettingId])
  @@map("story_stats")
}

model StoryStatLevel {
  id        String     @id @default(cuid())
  statId    String
  label     String
  minValue  Int
  maxValue  Int
  order     Int        @default(0)

  stat      StoryStat  @relation(fields: [statId], references: [id], onDelete: Cascade)

  @@index([statId])
  @@map("story_stat_levels")
}

model StoryMediaImage {
  id             String            @id @default(cuid())
  startSettingId String
  url            String
  key            String?
  order          Int               @default(0)
  createdAt      DateTime          @default(now())

  startSetting   StoryStartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)

  @@index([startSettingId])
  @@map("story_media_images")
}

model StoryKeywordNote {
  id             String            @id @default(cuid())
  startSettingId String
  title          String            @default("нӮӨмӣҢл“ң л…ёнҠё")
  keywords       String[]
  content        String            @db.Text
  order          Int               @default(0)
  triggerCount   Int               @default(0)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  startSetting   StoryStartSetting @relation(fields: [startSettingId], references: [id], onDelete: Cascade)

  @@index([startSettingId])
  @@map("story_keyword_notes")
}

// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
// STORY ENDINGS
// в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ
enum EndingGrade {
  N
  R
  SR
  SSR
}

model StoryEnding {
  id              String       @id @default(cuid())
  storyId         String
  startSettingId  String?
  grade           EndingGrade  @default(N)
  name            String       @db.VarChar(20)
  sortOrder       Int          @default(0)
  minTurnStart    Int          @default(10)
  prompt          String       @db.Text @default("")
  epilogue        String?      @db.Text
  hint            String?      @db.VarChar(20)
  imageUrl        String?
  imageKey        String?
  createdAt       DateTime     @default(now())
  updatedAt       DateTime     @updatedAt

  story           Story        @relation(fields: [storyId], references: [id], onDelete: Cascade)
  startSetting    StoryStartSetting? @relation(fields: [startSettingId], references: [id], onDelete: SetNull)
  rules           StoryEndingRule[]

  @@index([storyId])
  @@index([startSettingId])
  @@index([storyId, startSettingId, sortOrder])
  @@map("story_endings")
}

model StoryEndingRule {
  id         String      @id @default(cuid())
  endingId   String
  turnStart  Int         @default(10)
  sortOrder  Int         @default(0)
  createdAt  DateTime    @default(now())

  ending     StoryEnding @relation(fields: [endingId], references: [id], onDelete: Cascade)

  @@index([endingId])
  @@map("story_ending_rules")
}

// в”Җв”Җ мқҙлҜём§Җ мғқм„ұ в”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җв”Җ

enum ImageGenType {
  GENERATE
  TRANSFORM
}

enum ImageGenStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Terms {
  id          String   @id @default(cuid())
  type        String   // TERMS_OF_SERVICE, PRIVACY_POLICY, etc.
  version     String   // e.g. "1.0", "2.0"
  title       String
  content     String   @db.Text
  isActive    Boolean  @default(false) // нҳ„мһ¬ м Ғмҡ©мӨ‘мқё лІ„м „
  effectiveAt DateTime
  createdBy   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([type, isActive])
  @@index([type, effectiveAt(sort: Desc)])
  @@map("terms")
}

model GeneratedImage {
  id          String         @id @default(cuid())
  userId      String
  prompt      String         @db.Text
  style       String?
  ratio       String         @default("1:1")
  type        ImageGenType   @default(GENERATE)
  status      ImageGenStatus @default(PENDING)
  urls        String[]
  creditsUsed Int            @default(0)
  jobId       String?        @unique
  errorMsg    String?
  isLiked     Boolean        @default(false)
  sourceUrl   String?        // ліҖнҳ• мӢң мӣҗліё мқҙлҜём§Җ URL
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user        User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt(sort: Desc)])
  @@index([userId, isLiked])
  @@map("generated_images")
}

model CharacterComment {
  id          String   @id @default(cuid())
  characterId String
  userId      String
  content     String   @db.VarChar(500)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  character   Character @relation(fields: [characterId], references: [id], onDelete: Cascade)
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  reactions   CharacterCommentReaction[]

  @@index([characterId, createdAt(sort: Desc)])
  @@index([userId])
  @@map("character_comments")
}

model CharacterCommentReaction {
  id        String       @id @default(cuid())
  commentId String
  userId    String
  type      String       // "LIKE" | "DISLIKE"
  createdAt DateTime     @default(now())

  comment   CharacterComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([commentId])
  @@map("character_comment_reactions")
}

model NotificationBroadcast {
  id          String   @id @default(cuid())
  title       String
  body        String
  targetType  String   // "ALL" | "TIER" | "USER"
  targetValue String?  // tier name or userId
  sentCount   Int      @default(0)
  sentBy      String
  createdAt   DateTime @default(now())

  @@index([createdAt(sort: Desc)])
  @@map("notification_broadcasts")
}

model Post {
  id               String    @id @default(cuid())
  slug             String    @unique
  title            String
  subtitle         String?
  bannerImageUrl   String?
  content          Json
  category         String    @default("NOTICE")  // NOTICE | UPDATE | EVENT | MAINTENANCE
  status           String    @default("DRAFT")   // DRAFT | PUBLISHED
  isPinned         Boolean   @default(false)
  isFeatured       Boolean   @default(false)
  viewCount        Int       @default(0)
  sendNotification Boolean   @default(false)
  publishedAt      DateTime?
  expiresAt        DateTime?
  createdBy        String
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  @@index([status, publishedAt(sort: Desc)])
  @@index([isFeatured, status])
  @@index([slug])
  @@map("posts")
}
