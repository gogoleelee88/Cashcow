{
  "name": "@characterverse/api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "prisma generate && tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate deploy",
    "db:studio": "prisma studio",
    "clean": "rm -rf dist",
    "postinstall": "prisma generate"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.24.3",
    "@characterverse/types": "*",
    "@characterverse/utils": "*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@prisma/client": "^5.16.1",
    "@sentry/node": "^8.20.0",
    "@supabase/supabase-js": "^2.103.2",
    "aws-sdk": "^2.1672.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.12.5",
    "dotenv": "^16.4.5",
    "fastify": "^4.28.1",
    "fastify-plugin": "^4.5.1",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "openai": "^6.33.0",
    "pino": "^9.3.2",
    "prom-client": "^15.1.3",
    "socket.io": "^4.7.5",
    "stripe": "^16.2.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.10",
    "@types/uuid": "^10.0.0",
    "pino-pretty": "^13.0.0",
    "prisma": "^5.16.1",
    "tsx": "^4.16.2",
    "typescript": "^5.4.5"
  }
}