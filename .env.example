# ═══════════════════════════════════════════════════════════════
# CharacterVerse — Complete Environment Variables
# Copy to .env and fill in all values before running
# Generate secrets with: openssl rand -hex 32
# ═══════════════════════════════════════════════════════════════

# ── App ──────────────────────────────────────────────────────
NODE_ENV=development
PORT=4000
HOST=0.0.0.0
LOG_LEVEL=info

# Production URLs (change for each environment)
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001

# ── Database ─────────────────────────────────────────────────
POSTGRES_USER=characterverse
POSTGRES_PASSWORD=change_me_very_secure_password_min_32_chars
POSTGRES_DB=characterverse

# PgBouncer connection (production: use pooler port 6432)
DATABASE_URL=postgresql://characterverse:${POSTGRES_PASSWORD}@pgbouncer:6432/characterverse
# Direct connection for migrations (bypass pooler)
DATABASE_DIRECT_URL=postgresql://characterverse:${POSTGRES_PASSWORD}@postgres:5432/characterverse
# Read replica (optional, defaults to primary if not set)
DATABASE_READ_URL=postgresql://characterverse:${POSTGRES_PASSWORD}@postgres-read:5432/characterverse

# ── Redis ────────────────────────────────────────────────────
REDIS_PASSWORD=change_me_redis_password_min_32_chars
REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379
REDIS_TLS=false

# ── Security ─────────────────────────────────────────────────
# Generate: openssl rand -hex 64 (must be >= 32 chars)
JWT_ACCESS_SECRET=generate_64_char_hex_string_here_use_openssl_rand_hex_64
JWT_REFRESH_SECRET=generate_another_64_char_hex_string_for_refresh_tokens
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Generate: openssl rand -hex 32 (must be exactly 64 hex chars = 32 bytes)
ENCRYPTION_KEY=generate_exactly_64_hex_chars_32_bytes_for_aes256_encryption

# ── AI (Anthropic) ───────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-api03-...
ANTHROPIC_HAIKU_MODEL=claude-haiku-4-5-20251001
ANTHROPIC_SONNET_MODEL=claude-sonnet-4-6

# ── AWS S3 / CloudFront ──────────────────────────────────────
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=characterverse-assets
# CloudFront CDN URL for serving uploaded assets
AWS_CLOUDFRONT_URL=https://d1234abcd.cloudfront.net

# ── OAuth — Google ───────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...

# ── OAuth — Kakao ────────────────────────────────────────────
# https://developers.kakao.com/console/app
KAKAO_CLIENT_ID=...
KAKAO_CLIENT_SECRET=...  # Optional if using native app key only

# ── OAuth — Apple ────────────────────────────────────────────
# https://developer.apple.com/account/resources/identifiers/list
APPLE_CLIENT_ID=ai.characterverse.app
APPLE_TEAM_ID=XXXXXXXXXX
APPLE_KEY_ID=XXXXXXXXXX
# Paste the full private key content (include -----BEGIN/END PRIVATE KEY-----)
APPLE_PRIVATE_KEY=

# ── Payments — Toss (Korea) ──────────────────────────────────
# https://developers.tosspayments.com
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=...

# ── Payments — Stripe (International) ───────────────────────
# https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ── Monitoring ───────────────────────────────────────────────
# https://sentry.io → Projects → DSN
SENTRY_DSN=https://abc123@o0.ingest.sentry.io/0

# Slack Incoming Webhook for critical alerts
# https://api.slack.com/messaging/webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T.../B.../...

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_PASSWORD=change_me_grafana_admin_password

# ── Next.js (web app only) ───────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:4000
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Docker / Production ──────────────────────────────────────
# SSH key for deployment target
PRODUCTION_HOST=your-server.com
PRODUCTION_USER=deploy

# ── Settlement ───────────────────────────────────────────────
# Minimum payout threshold in KRW (default: 10,000)
SETTLEMENT_MIN_AMOUNT=10000
# Platform fee rate (default: 0.30 = 30%)
PLATFORM_FEE_RATE=0.30
