# ── Root .env.example — copy to .env and fill in values ──

# PostgreSQL
POSTGRES_PASSWORD=change_me_secure_password

# Redis
REDIS_PASSWORD=change_me_redis_password

# JWT (generate with: openssl rand -hex 64)
JWT_ACCESS_SECRET=generate_64_char_hex_string_here
JWT_REFRESH_SECRET=generate_another_64_char_hex_string_here

# Encryption (generate with: openssl rand -hex 32)
ENCRYPTION_KEY=generate_32_byte_hex_64_char_string_here

# NextAuth
NEXTAUTH_SECRET=generate_random_secret

# Anthropic
ANTHROPIC_API_KEY=sk-ant-...

# AWS
AWS_REGION=ap-northeast-2
AWS_ACCESS_KEY_ID=AKIA...
AWS_SECRET_ACCESS_KEY=...
AWS_S3_BUCKET=characterverse-assets
AWS_CLOUDFRONT_URL=https://d1234.cloudfront.net

# URLs
API_BASE_URL=http://localhost:4000
WEB_BASE_URL=http://localhost:3000
ALLOWED_ORIGINS=http://localhost:3000

# OAuth
GOOGLE_CLIENT_ID=...
GOOGLE_CLIENT_SECRET=...
KAKAO_CLIENT_ID=...
KAKAO_CLIENT_SECRET=...

# Payments
TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...
TOSS_WEBHOOK_SECRET=...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Monitoring
SENTRY_DSN=https://...@sentry.io/...
SLACK_WEBHOOK_URL=https://hooks.slack.com/...
GRAFANA_PASSWORD=secure_grafana_password
